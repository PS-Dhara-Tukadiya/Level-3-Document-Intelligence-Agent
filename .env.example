# LiteLLM API Configuration
LITELLM_BASE_URL=https://litellm-api.predev.praveg.ai/v1
LITELLM_API_KEY=your-litellm-key-here

# Vision model used automatically when one or more pictures are attached to a
# request (the default text model above cannot see images). Set this to a
# vision-capable model your LiteLLM proxy exposes.
VISION_MODEL=deepinfra/Qwen/Qwen2.5-VL-32B-Instruct

# Server Config
API_KEYS=dev-key-123,test-key-456
PORT=3000
