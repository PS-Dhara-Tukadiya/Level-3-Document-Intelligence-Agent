{
  "name": "doc-intelligence-agent",
  "version": "1.0.0",
  "description": "Production-ready Document Intelligence Agent powered by LiteLLM",
  "main": "src/agent.js",
  "scripts": {
    "start": "node api/server.js",
    "cli": "node cli/index.js",
    "eval": "node evals/eval_runner.js",
    "eval:qa": "node evals/eval_runner.js --suite=qa",
    "eval:security": "node evals/eval_runner.js --suite=security",
    "eval:strict": "node evals/eval_runner.js --threshold=0.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "node-fetch": "^2.7.0"
  },
  "keywords": [
    "ai",
    "agent",
    "document-intelligence",
    "rag",
    "litellm"
  ]
}
